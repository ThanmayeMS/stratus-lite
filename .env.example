# Backend: local PostgreSQL or Render environment variables.
SPRING_PROFILES_ACTIVE=postgres
SPRING_DATASOURCE_URL=replace-with-neon-jdbc-url
SPRING_DATASOURCE_USERNAME=replace-with-neon-username
SPRING_DATASOURCE_PASSWORD=replace-with-neon-password
STRATUS_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,https://*.vercel.app

# Frontend: set this on Vercel to the deployed Render backend URL.
VITE_STRATUS_API_BASE_URL=https://stratus-lite-api.onrender.com/api
